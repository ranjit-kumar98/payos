# Example environment variables for PayOS project
# Copy this file to .env and fill in real values before use

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=payos

# Redis
REDIS_PASSWORD=your_redis_password

# Kafka
KAFKA_BROKER_ID=1
KAFKA_NODE_ID=1
KAFKA_CLUSTER_ID=your_kafka_cluster_id

# Ports
POSTGRES_PORT=5432
REDIS_PORT=6379
KAFKA_PORT=9092
KAFKA_UI_PORT=8080
REDIS_COMMANDER_PORT=8081
BACKEND_PORT=8000
NOTIFICATION_SERVICE_PORT=3001
FRONTEND_PORT=3000
NGINX_PORT=80